# ============================================================
# AutoApply Bot — environment template
# Copy to .env and fill in. Never commit the real .env.
# ============================================================

# --- Database ---
# Set DATABASE_URL only. The Alembic migration tool auto-derives the
# psycopg2 (sync) version from this. DATABASE_URL_SYNC is optional and
# only needed if you want to override the auto-derivation.
#
# Neon (recommended): copy the connection string from the Neon dashboard,
#   it looks like:
#     postgresql://USER:PASS@ep-xxx-pooler.aws.neon.tech/autoapply?sslmode=require
#   Paste it directly. core/db.py and migrations/env.py both handle the
#   driver-prefix and ssl-param translation automatically.
#
# Local Docker Postgres:
#     postgresql+asyncpg://autoapply:autoapply@localhost:5432/autoapply
DATABASE_URL=

# Optional. Leave blank for auto-derivation from DATABASE_URL.
# Only set this if your sync driver needs a different host/credentials.
DATABASE_URL_SYNC=

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=

# --- Encryption (Fernet key for user SMTP passwords) ---
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ROTATING THIS KEY INVALIDATES ALL STORED USER CREDENTIALS — they must reconnect.
ENCRYPTION_KEY=

# --- Job data source: Adzuna (primary) ---
# Sign up: https://developer.adzuna.com/signup  (free 1000 calls/month)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Job data source: JSearch via RapidAPI (fallback, optional) ---
RAPIDAPI_KEY=

# --- LLM scoring (shared across all users) ---
GROQ_API_KEY=

# --- Outbound mail ---
# There is no operator-side mail configuration. Each user supplies their
# own Gmail address + app password during /start onboarding; outbound
# uses Gmail SMTP from their account (500 emails/day per user quota,
# replies land natively in their inbox). The app password is stored
# encrypted under UserCredentials.smtp_password_encrypted (Fernet).
#
# Future: a Pro-tier "managed sending" option may add RESEND_API_KEY +
# RESEND_FROM_DOMAIN here for zero-setup users \u2014 not wired today.

# --- Recruiter enrichment ---
# Hunter is OPERATOR-POOL ONLY (shared across all users). Hunter's signup
# requires a work email, which most job-seekers don't have, so we never ask
# users for their own Hunter key. Free plan: 25 lookups/month for the pool.
HUNTER_API_KEY=
# Apollo is USER-SUPPLIED only (entered during onboarding, stored encrypted
# per user). Apollo accepts Gmail signups. The variable below is unused by
# application code and kept only for backward compatibility with old .env
# files \u2014 safe to delete.
APOLLO_API_KEY=

# --- Payments ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_MONTHLY_INR=         # e.g. price_1A2B3C... ₹299/mo

# --- Deployment ---
PUBLIC_BASE_URL=http://localhost:8000  # used for Stripe Checkout return URL + webhooks
ENVIRONMENT=development                # development | staging | production
